{
  "name": "@kaustubhdurgade/rchive",
  "version": "1.0.2",
  "description": "Local-first AI conversation archive — import ChatGPT/Claude exports, enrich with topics and embeddings, and query via MCP",
  "type": "module",
  "bin": {
    "rchive": "./dist/cli.js"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "prepublishOnly": "npm test && npm run build",
    "dev": "ts-node src/cli.ts",
    "start": "node dist/cli.js",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KaustubhDurgade/rchive.git"
  },
  "keywords": [
    "mcp",
    "ai",
    "chatgpt",
    "claude",
    "conversation",
    "archive",
    "search",
    "rag",
    "sqlite",
    "ollama",
    "groq",
    "cli"
  ],
  "author": "Kaustubh Durgade <kaustubhdurgade1@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/KaustubhDurgade/rchive/issues"
  },
  "homepage": "https://github.com/KaustubhDurgade/rchive#readme",
  "overrides": {
    "protobufjs": "^8.2.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xenova/transformers": "^2.17.2",
    "adm-zip": "^0.5.17",
    "better-sqlite3": "^12.9.0",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "groq-sdk": "^1.2.0",
    "ink": "^7.0.2",
    "ink-select-input": "^6.2.0",
    "ink-text-input": "^6.0.0",
    "keytar": "^7.9.0",
    "ora": "^9.4.0",
    "react": "^19.2.6",
    "sqlite-vec": "^0.1.9"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
